# GatherHub signed public API — used only by scripts/fetch-gatherhub.mjs at
# BUILD time. Never referenced from client code; secrets never reach the bundle.
# Required only when a class in src/data/classes.json has a gatherhub_event_uuid.
GATHERHUB_BASE_URL=https://my.gatherhub.app
GATHERHUB_CLIENT_KEY=
GATHERHUB_CLIENT_SECRET=
GATHERHUB_CLIENT_DOMAIN=devhub.my
